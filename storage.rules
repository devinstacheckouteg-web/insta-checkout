rules_version = '2';
// Firebase Storage rules for gs://instacheckout-a4141.firebasestorage.app
// Deploy with: firebase deploy --only storage

service firebase.storage {
  match /b/{bucket}/o {
    // Product images: products/{firebaseUid}/{productId}_{timestamp}_{shortId}.ext
    match /products/{userId}/{fileName} {
      allow read: if true;  // Public for checkout display
      allow write: if request.auth != null
                  && request.auth.uid == userId
                  && request.resource.size < 5 * 1024 * 1024   // 5 MB max
                  && request.resource.contentType.matches('image/.*');
    }
  }
}
